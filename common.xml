<?xml version="1.0" encoding="UTF-8"?>
<!-- ================================================================= -->
<!-- VOIP PHONE CLUB  -  COMMON CONFIG  (shared by ALL H2U-V2 phones)  -->
<!-- Host this as the Common configuration on the provisioning server. -->
<!-- Contains NO secrets, so encryption is optional.                   -->
<!--                                                                   -->
<!-- IMPORTANT: H2U-V2 phones request this file as F0V2UV200000.cfg    -->
<!-- (observed in Worker logs 2026-07-18), NOT as common.xml. Upload   -->
<!-- it under that key with upload_common_alias.py; after editing this -->
<!-- file, delete the old R2 object by hand and re-run that script.    -->
<!--                                                                   -->
<!-- Edits vs a member's known-good export:                                   -->
<!--   * AllowIPCall 1 -> 0  (children cannot dial raw IP addresses)   -->
<!--   * Dial plan ^1[0-9][0-9]$ -> ^[12][0-9][0-9]$ (covers ext 200)  -->
<!--   * DND window 1500-1730 -> 2100-0800 (quiet hours 21:00-08:00)   -->
<!--   * Added <sip> UseVPN=0, <phone><date> UTC+1 + SNTP, EnableVPN=0 -->
<!--     (TimeZone 4 = UTC+1 VERIFIED against a handset 2026-07-19)    -->
<!--   * Added EU DST rules (verified same day): without them phones   -->
<!--     run winter time all summer and DND fires an hour late         -->
<!-- Everything else is that export's call behaviour, unchanged.   -->
<!-- ================================================================= -->
<sysConf>
    <Version>2.0000000000</Version>
    <sip>
        <line index="1">
            <UseVPN>0</UseVPN>
        </line>
        <line index="2">
            <UseVPN>0</UseVPN>
        </line>
    </sip>
    <call>
        <port index="1">
            <EnableXferDPlan>1</EnableXferDPlan>
            <EnableFwdDPlan>0</EnableFwdDPlan>
            <EnablePreDPlan>0</EnablePreDPlan>
            <IPDialPrefix>.</IPDialPrefix>
            <EnableDND>1</EnableDND>
            <DNDMode>0</DNDMode>
            <EnableSpaceDND>0</EnableSpaceDND>
            <DNDStartTime>2100</DNDStartTime>
            <DNDEndTime>0800</DNDEndTime>
            <DNDAcceptMcast>0</DNDAcceptMcast>
            <EnableCallBar>1</EnableCallBar>
            <EnableAllowedlist>1</EnableAllowedlist>
            <EnableBlockedlist>1</EnableBlockedlist>
            <MuteRinging>0</MuteRinging>
            <BanDialOut>0</BanDialOut>
            <BanDialOutToneMode>1</BanDialOutToneMode>
            <BanDialOutTone></BanDialOutTone>
            <BanEmptyCID>0</BanEmptyCID>
            <EnableCLIP>1</EnableCLIP>
            <CallWaiting>0</CallWaiting>
            <CallTransfer>1</CallTransfer>
            <CallSemiXfer>1</CallSemiXfer>
            <CallConference>0</CallConference>
            <AutoPickupNext>0</AutoPickupNext>
            <BusyNoLine>1</BusyNoLine>
            <AutoOnhook>1</AutoOnhook>
            <AutoOnhookTime>3</AutoOnhookTime>
            <EnableIntercom>0</EnableIntercom>
            <IntercomMute>0</IntercomMute>
            <IntercomTone>0</IntercomTone>
            <IntercomBarge>0</IntercomBarge>
            <UseAutoRedial>0</UseAutoRedial>
            <RedialEnterCallLog>0</RedialEnterCallLog>
            <AutoRedialDelay>30</AutoRedialDelay>
            <AutoRedialTimes>5</AutoRedialTimes>
            <CallComplete>0</CallComplete>
            <CHoldingTone>1</CHoldingTone>
            <CWaitingTone>1</CWaitingTone>
            <HideDTMFType>0</HideDTMFType>
            <VideoDisplayMode>0</VideoDisplayMode>
            <TalkDTMFTone>1</TalkDTMFTone>
            <DialDTMFTone>1</DialDTMFTone>
            <PswDialMode>0</PswDialMode>
            <PswDialLength>0</PswDialLength>
            <PswDialPrefix></PswDialPrefix>
            <EnableMultiLine>1</EnableMultiLine>
            <AllowIPCall>0</AllowIPCall>
            <CallerNameType>0</CallerNameType>
            <MuteForRing>0</MuteForRing>
            <AutoHandleVideo>0</AutoHandleVideo>
            <DefaultAnsMode>1</DefaultAnsMode>
            <DefaultDialMode>1</DefaultDialMode>
            <HoldToTransfer>0</HoldToTransfer>
            <EnablePreDial>0</EnablePreDial>
            <DefaultExtLine>1</DefaultExtLine>
            <EnableDefLine>1</EnableDefLine>
            <EnableSelLine>1</EnableSelLine>
            <RinginHeadset>0</RinginHeadset>
            <AutoHeadset>0</AutoHeadset>
            <DNDReturnCode>480</DNDReturnCode>
            <BusyReturnCode>486</BusyReturnCode>
            <RejectReturnCode>603</RejectReturnCode>
            <ContactType>0</ContactType>
            <EnableCountryCode>0</EnableCountryCode>
            <CountryCode></CountryCode>
            <CallAreaCode></CallAreaCode>
            <NumberPrivacy>0</NumberPrivacy>
            <PrivacyRule></PrivacyRule>
            <TransfDTMFCode></TransfDTMFCode>
            <HoldDTMFCode></HoldDTMFCode>
            <ConfDTMFCode></ConfDTMFCode>
            <DisableDialSearch>0</DisableDialSearch>
            <CallNumberFilter></CallNumberFilter>
            <AutoResumeCurrent>0</AutoResumeCurrent>
            <CallTimeout>120</CallTimeout>
            <RingTimeout>120</RingTimeout>
            <RingPriority>1</RingPriority>
            <AutoAnswerTone>1</AutoAnswerTone>
            <AlertingTone>1</AlertingTone>
            <BusyTone>1</BusyTone>
            <AlertInfoUrlEnable>1</AlertInfoUrlEnable>
            <AlertInfoTextEnable>1</AlertInfoTextEnable>
            <AlertInfoKeywordsEnable>1</AlertInfoKeywordsEnable>
            <DisableSpeakerMode>0</DisableSpeakerMode>
        </port>
        <basic>
            <DialbyPound>0</DialbyPound>
            <BTransferbyPound>0</BTransferbyPound>
            <OnhooktoBXfer>0</OnhooktoBXfer>
            <OnhooktoAXfer>0</OnhooktoAXfer>
            <ConfOnhooktoXfer>0</ConfOnhooktoXfer>
            <DialFixedLength>1</DialFixedLength>
            <FixedLengthNums>3</FixedLengthNums>
            <DialbyTimeout>1</DialbyTimeout>
            <DialTimeoutvalue>5</DialTimeoutvalue>
            <EnableEOneSixFour>0</EnableEOneSixFour>
        </basic>
        <dialplan index="1">
            <Number>^[12][0-9][0-9]$</Number>
            <ApplyToCall>0</ApplyToCall>
            <MatchToSend>1</MatchToSend>
            <Media>0</Media>
            <Line>1</Line>
            <Address></Address>
            <Port>0</Port>
            <Alias></Alias>
            <DelLen>0</DelLen>
            <Suffix></Suffix>
        </dialplan>
        <alertInfo index="1">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="2">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="3">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="4">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="5">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="6">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="7">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="8">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="9">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
        <alertInfo index="10">
            <Text></Text>
            <Line>-1</Line>
            <RingType>1.wav</RingType>
        </alertInfo>
    </call>
    <phone>
        <date>
            <EnableSNTP>1</EnableSNTP>
            <SNTPServer>0.pool.ntp.org</SNTPServer>
            <SecondSNTPServer>time.nist.gov</SecondSNTPServer>
            <TimeZone>4</TimeZone>
            <TimeZoneName>UTC+1</TimeZoneName>
            <!-- EU daylight saving (last Su of Mar -> last Su of Oct, +60min).
                 Without this the phones sit on winter time all summer and the
                 21:00 DND fires at 22:00 real time. Values copied verbatim
                 2026-07-19 from a handset configured via the web UI
                 (Location Netherlands(Amsterdam), DST Automatic) and verified
                 to show the correct clock. -->
            <DSTType>1</DSTType>
            <DSTLocation>16</DSTLocation>
            <DSTRuleMode>0</DSTRuleMode>
            <DSTMinOffset>60</DSTMinOffset>
            <DSTStartMon>3</DSTStartMon>
            <DSTStartWeek>5</DSTStartWeek>
            <DSTStartWday>0</DSTStartWday>
            <DSTStartHour>2</DSTStartHour>
            <DSTEndMon>10</DSTEndMon>
            <DSTEndWeek>5</DSTEndWeek>
            <DSTEndWday>0</DSTEndWday>
            <DSTEndHour>2</DSTEndHour>
        </date>
    </phone>
    <vpn>
        <EnableVPN>0</EnableVPN>
    </vpn>
</sysConf>
