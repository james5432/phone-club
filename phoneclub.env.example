# phoneclub.env.example — copy to phoneclub.env and fill in your values.
#
#     cp phoneclub.env.example phoneclub.env
#     chmod 600 phoneclub.env
#
# Load into your terminal with `source phoneclub.env` BEFORE running the
# scripts (or launching Claude Code) in that same terminal.
#
# phoneclub.env is gitignored. Never commit it: anyone with these values
# controls the whole phone network.

# --- VoIP.ms -----------------------------------------------------------------
# ACCOUNT is your main account number; SERVER is the POP your phones register
# to (pick one close to you, e.g. amsterdam.voip.ms).
# API_USER is your VoIP.ms portal login (email).
# API_PASS is the API password set under: Main Menu > SOAP and REST/JSON API
# (enable the API there and whitelist this machine's IP address).
export VOIPMS_ACCOUNT=""
export VOIPMS_SERVER=""
export VOIPMS_API_USER=""
export VOIPMS_API_PASS=""

# --- Cloudflare R2 -----------------------------------------------------------
# Create an R2 API token in the Cloudflare dashboard (R2 > Manage API tokens).
# ENDPOINT uses your Cloudflare account ID: https://<account-id>.r2.cloudflarestorage.com
export R2_ENDPOINT=""
export R2_ACCESS_KEY_ID=""
export R2_SECRET_ACCESS_KEY=""
export R2_BUCKET=""

# --- Local paths -------------------------------------------------------------
# Path to the per-MAC config template (built from a known-good exported .cfg).
export PHONE_CFG_TEMPLATE="phone.cfg.template"
